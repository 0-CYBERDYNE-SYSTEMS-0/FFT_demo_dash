{
  "name": "fft-demo-dash",
  "version": "1.0.0",
  "description": "FarmFriend Terminal - Home Assistant Smart Farm Demo",
  "type": "module",
  "scripts": {
    "ha:start": "docker-compose up -d",
    "ha:stop": "docker-compose down",
    "ha:logs": "docker-compose logs -f homeassistant",
    "ha:restart": "docker-compose restart homeassistant",
    "simulate:telemetry": "tsx scripts/simulate-farm-telemetry.ts",
    "simulate:demo": "tsx scripts/simulate-farm-telemetry.ts",
    "test:ha": "tsx scripts/test-ha-connection.ts",
    "qa:media-guard": "bash scripts/qa-no-placeholders.sh",
    "qa:live-embeds": "node scripts/qa-live-embeds.mjs",
    "qa:cannabis-clone": "node scripts/qa-cannabis-clone.mjs",
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "qa:cannabis-taxonomy": "node scripts/qa-cannabis-taxonomy.mjs",
    "demo:weather": "tsx scripts/weather-provider.ts",
    "demo:mirror": "tsx scripts/mirror-environment.ts",
    "demo:set-location": "tsx scripts/set-demo-location.ts",
    "simulate:timelapse": "SIM_TIMELAPSE=true tsx scripts/simulate-farm-telemetry.ts",
    "simulate:replay": "tsx scripts/simulate-farm-telemetry.ts --replay"
  },
  "dependencies": {
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "playwright": "^1.58.2",
    "tsx": "^4.19.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=20"
  }
}
