# Environment Configuration for FarmFriend HA Integration
# Copy this to .env and fill in your HA token

# Home Assistant URL
HA_URL=http://localhost:8123

# IMPORTANT: Get your Long-Lived Access Token from:
# 1. Open http://localhost:8123/profile in your browser
# 2. Click on "Security" tab
# 3. Click "Create Token" under Long-Lived Access Tokens
# 4. Give it a name (e.g., "FarmFriend Demo")
# 5. Copy the token and paste it below
HA_TOKEN=YOUR_LONG_LIVED_ACCESS_TOKEN_HERE
